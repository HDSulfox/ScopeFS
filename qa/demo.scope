format
login root root
scope
dir /
mkdir /course
mkdir /course/lab
create /course/lab/report 0644
open /course/lab/report rw
write 3 ScopeFS traceable kernel model
close 3
snapshot create baseline
cp /course/lab/report /course/lab/report.copy
open /course/lab/report.copy append
write 4  + COW branch
close 4
snapshot create after_copy
snapshot diff baseline after_copy
scope tree
map refcount
trace 18
fsck
exit
